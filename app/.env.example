# WineSnob app — client environment.
# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings -> API). These are safe to expose in the browser.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# The Anthropic API key is NOT set here. It lives only on the server as a
# Supabase Edge Function secret (ANTHROPIC_API_KEY) and is never shipped to
# the browser.
